MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ai_app
MYSQL_USER=ai_user
MYSQL_PASSWORD=ai_password
# Optional. Use these when the app user does not already exist or cannot create databases.
MYSQL_ADMIN_USER=
MYSQL_ADMIN_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY_POOL=threads
CELERY_CONCURRENCY=4

APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false

STORAGE_ROOT=./data
UPLOAD_DIR=./data/uploads
INGEST_CHUNK_SIZE=800
INGEST_CHUNK_OVERLAP=100

EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=auto
EMBEDDING_NORMALIZE=true
EMBEDDING_QUERY_PREFIX=
EMBEDDING_DOCUMENT_PREFIX=

# Local vLLM startup helper variables
VLLM_MODEL_PATH=
VLLM_SERVED_MODEL_NAME=
VLLM_HOST=0.0.0.0
VLLM_PORT=9000
VLLM_API_KEY=
VLLM_CUDA_VISIBLE_DEVICES=
VLLM_DTYPE=auto
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=

LLM_ENABLE=true
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://127.0.0.1:9000/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2
CHAT_TOP_K=5
CHAT_MIN_RETRIEVAL_SCORE=0.0
CHAT_MAX_CHUNK_CHARS=1000
STREAM_DELTA_CHARS=20
STREAM_MOCK_DELAY_MS=30
CHAT_ENABLE_MOCK_FALLBACK=true
