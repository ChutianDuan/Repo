{
  "listeners": [
    {
      "address": "0.0.0.0",
      "port": 8080,
      "https": false
    }
  ],
  "app": {
    "threads_num": 4,
    "enable_session": false,
    "document_root": "./",
    "client_max_body_size": "100M"
  },
  "db_clients": [
    {
      "name": "default",
      "rdbms": "mysql",
      "host": "127.0.0.1",
      "port": 3306,
      "dbname": "ai_app",
      "user": "ai_user",
      "passwd": "ai_password",
      "connection_number": 1,
      "is_fast": false,
      "timeout": -1.0
    }
  ],
  "redis_clients": [
    {
      "name": "default",
      "host": "127.0.0.1",
      "port": 6379,
      "passwd": "",
      "db": 0,
      "is_fast": false,
      "number_of_connections": 1,
      "timeout": -1.0
    }
  ],
  "log": {
    "log_path": "./logs",
    "logfile_base_name": "cpp_gateway",
    "log_size_limit": 100000000,
    "max_files": 10,
    "display_local_time": true
  }
}
